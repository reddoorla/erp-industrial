{
	"name": "sveltekit-starter-prismic-minimal",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "concurrently \"npm:vite:dev\" \"npm:slicemachine\" --prefix-colors blue,magenta",
		"vite:dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"lint": "prettier --check . --plugin prettier-plugin-svelte . && eslint .",
		"format": "prettier --write . --plugin prettier-plugin-svelte .",
		"slicemachine": "start-slicemachine"
	},
	"devDependencies": {
		"@slicemachine/adapter-sveltekit": "^0.3.65",
		"@sveltejs/adapter-auto": "^3.3.1",
		"@sveltejs/kit": "^2.16.1",
		"@sveltejs/vite-plugin-svelte": "^3.1.2",
		"autoprefixer": "^10.4.20",
		"concurrently": "^8.2.2",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.1",
		"postcss": "^8.5.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"sass": "^1.83.4",
		"slice-machine-ui": "^1.26.0",
		"svelte": "^4.2.19",
		"svelte-check": "^3.8.6",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.7.3",
		"typescript-svelte-plugin": "^0.3.45",
		"vite": "^5.4.14"
	},
	"type": "module",
	"dependencies": {
		"@prismicio/client": "^7.15.1",
		"@prismicio/helpers": "^2.3.9",
		"@prismicio/svelte": "^1.3.1",
		"@sendgrid/mail": "^8.1.4",
		"@vimeo/player": "^2.25.0",
		"svelte-gestures": "^4.0.0"
	}
}
